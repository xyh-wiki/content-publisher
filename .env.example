DB_URL=jdbc:postgresql://postgres:5432/content_publisher
DB_USERNAME=content_publisher
DB_PASSWORD=replace-with-a-secret
PUBLISHER_SERVICE_DATA_DIR=/data/services/content-publisher/data
PUBLISHER_SECURITY_ENABLED=true
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=https://identity.example.com/realms/content-publisher
PUBLISHER_SECURITY_TENANT_CLAIM=tenant_id
PUBLISHER_SECURITY_ROLES_CLAIM=roles
PUBLISHER_JOBS_WORKER_ENABLED=true
PUBLISHER_JOBS_MAX_ACTIVE_PER_TENANT=20
PUBLISHER_JOBS_MAX_ATTEMPTS=4
PUBLISHER_JOBS_LOCK_TIMEOUT=5m
PUBLISHER_AI_ENABLED=true
PUBLISHER_AI_BASE_URL=https://your-ai-gateway.example.com/v1
PUBLISHER_AI_API_KEY=replace-with-a-secret
PUBLISHER_AI_MODEL=your-model-name
PUBLISHER_AI_TEMPERATURE=0.2
GIT_ALLOWED_HOSTS=github.com,gitlab.com,gitee.com
