DB_URL=jdbc:postgresql://postgres:5432/content_publisher
DB_USERNAME=content_publisher
DB_PASSWORD=replace-with-a-secret
PUBLISHER_SERVICE_DATA_DIR=/data/services/content-publisher/data
SERVER_ADDRESS=127.0.0.1
PUBLISHER_SECURITY_ENABLED=true
PUBLISHER_LOCAL_SECURITY_ENABLED=false
PUBLISHER_LOCAL_ADMIN_USERNAME=
PUBLISHER_LOCAL_ADMIN_PASSWORD=
PUBLISHER_LOCAL_ADMIN_TENANT=local
PUBLISHER_LOCAL_ADMIN_MUST_CHANGE_PASSWORD=true
PUBLISHER_SESSION_COOKIE_SECURE=true
PUBLISHER_SESSION_TIMEOUT=30m
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=https://identity.example.com/realms/content-publisher
PUBLISHER_SECURITY_TENANT_CLAIM=tenant_id
PUBLISHER_SECURITY_ROLES_CLAIM=roles
PUBLISHER_JOBS_WORKER_ENABLED=true
PUBLISHER_JOBS_MAX_ACTIVE_PER_TENANT=20
PUBLISHER_JOBS_MAX_ATTEMPTS=4
PUBLISHER_JOBS_LOCK_TIMEOUT=5m
PUBLISHER_AI_ENABLED=true
PUBLISHER_AI_BASE_URL=https://your-ai-gateway.example.com/v1
PUBLISHER_AI_API_KEY=replace-with-a-secret
PUBLISHER_AI_MODEL=your-model-name
PUBLISHER_AI_TEMPERATURE=0.2
# 可选：限制管理后台只能保存这些 AI 域名；空值表示允许任意公网 HTTPS 域名
PUBLISHER_AI_ALLOWED_HOSTS=your-ai-gateway.example.com
# 仅本机受控 AI 服务才可显式设为 true；默认禁止回环和私网地址
PUBLISHER_AI_ALLOW_PRIVATE_ADDRESSES=false
# 使用 openssl rand -base64 32 生成，用于加密数据库内的 API Key，启用后不得丢失或随意更换
PUBLISHER_SECRETS_ENCRYPTION_KEY=
PUBLISHER_CHANNELS_ENABLED=false
# 使用 openssl rand -base64 32 生成，启用后不得随意更换
PUBLISHER_CHANNELS_ENCRYPTION_KEY=
# WordPress、Discourse、Mastodon 与 Ghost 自托管站点域名允许列表
PUBLISHER_CHANNELS_ALLOWED_HOSTS=community.example.com,blog.example.com
PUBLISHER_CHANNELS_TIMEOUT=30s
GIT_ALLOWED_HOSTS=github.com,gitlab.com,gitee.com
